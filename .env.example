# ── API Keys ──
DEEPSEEK_API_KEY=sk-your-key-here
ZHIPUAI_API_KEY=your-key-here.xxx
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
